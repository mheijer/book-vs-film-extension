{
  "manifest_version": 3,
  "name": "Book vs. Film xRay",
  "version": "1.0",
  "minimum_chrome_version": "114",
  "description": "Compare Netflix scenes to their source books using Claude AI.",
  "permissions": ["sidePanel", "activeTab"],
  "host_permissions": [
    "https://book-vs-film-extension-production.up.railway.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.netflix.com/*",
        "https://*.hbomax.com/*",
        "https://*.max.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Book vs. Film xRay"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
